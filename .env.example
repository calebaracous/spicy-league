# Node environment — set automatically by Next.js, leave blank for dev
NODE_ENV=

# Public URL of the app. Used for magic-link callback URLs and canonical links.
# Dev: http://localhost:3000  Prod: https://spicy-league.vercel.app (or your domain)
NEXT_PUBLIC_APP_URL=

# Postgres connection string (Neon). Required once DB-backed features are in use.
# Example: postgresql://user:pass@host.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Auth.js — generate with `openssl rand -base64 32`
AUTH_SECRET=

# Resend API key for magic-link delivery
AUTH_RESEND_KEY=

# Address magic-link emails send from. Must be on a domain verified in Resend.
AUTH_EMAIL_FROM=

# Riot Games API key
# Get a Developer Key (24h expiring) at https://developer.riotgames.com
# Apply for a Personal API Key for stable non-expiring access
RIOT_DEVELOPER_API_KEY=

# Vercel Blob (for avatar uploads) — auto-injected when Blob store is attached
BLOB_READ_WRITE_TOKEN=

# Upstash Redis (for rate limiting) — unset is fine; rate limiting no-ops without these
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Set to 1 to skip env validation (use only in CI for non-runtime builds)
SKIP_ENV_VALIDATION=
